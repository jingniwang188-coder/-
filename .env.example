# DeepSeek Chat Completions key. The current code reads this name for historical reasons.
OPENAI_API_KEY=

# Comma-separated allowed browser origins.
ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app

# PostgreSQL connection for VIP payment orders.
DATABASE_URL=
PGSSLMODE=

# VIP unlock and test access.
VIP_UNLOCK_CODE=
VIP_SIGNING_SECRET=
VIP_FRIEND_TEST_CODES=FRIEND,FRIENDS
VIP_ADMIN_KEY=

# Static Alipay QR fallback. Used when Alipay precreate is not configured or fails.
VIP_ALIPAY_QR_IMAGE_URL=https://your-domain.com/alipay-qr.PNG

# Alipay precreate and async notify.
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-project.vercel.app/api/vip-payment-alipay-notify

# Feedback email via Resend.
RESEND_API_KEY=
FEEDBACK_TO_EMAIL=
FEEDBACK_FROM_EMAIL=
